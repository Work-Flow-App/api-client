{
  "name": "@work-flow-app/api-client",
  "version": "1.0.0",
  "description": "Generated TypeScript API client for WorkFlow App",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./hooks": {
      "types": "./dist/types/hooks.d.ts",
      "import": "./dist/esm/hooks.js",
      "require": "./dist/cjs/hooks.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "orval --config orval.config.ts",
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist/types",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@types/node": "^20.0.0",
    "orval": "^7.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Work-Flow-App/api-client.git"
  }
}
